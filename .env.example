# ============================================================
# 环境变量配置模板
# 使用方法：复制此文件为 .env 并填入真实的 API 密钥
# 注意：.env 文件不应提交到版本控制系统
# ============================================================

# TextIn OCR 配置
TEXTIN_APP_ID=your_app_id_here
TEXTIN_SECRET_CODE=your_secret_code_here

# LLM API 配置
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-v3.2

# 服务配置
HOST=0.0.0.0
PORT=8001